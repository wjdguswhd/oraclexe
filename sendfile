SELECT 
    JSON_VALUE(FULL_DATA, '$.aplyYmd') AS aplyYmd,
    CASE WHEN JSON_VALUE(FULL_DATA, '$.aplyYmd') IS NULL THEN '1.NULL'
         WHEN NOT REGEXP_LIKE(JSON_VALUE(FULL_DATA, '$.aplyYmd'), '~') THEN '2.NO_TILDE'
         WHEN TO_DATE(TRIM(REGEXP_SUBSTR(JSON_VALUE(FULL_DATA, '$.aplyYmd'), '[0-9]{8}$')), 'YYYYMMDD') >= SYSDATE THEN '3.NOT_EXPIRED'
         ELSE '4.EXPIRED'
    END AS reason
FROM WELFARE
WHERE LCLSF_NM LIKE '%금융･복지･문화%'
FETCH FIRST 30 ROWS ONLY;
