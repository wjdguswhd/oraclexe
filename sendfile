<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.moa.backend.welfare.model.mapper.WelfareMapper">

	<!-- DB에 API정보 저장 -->
    <insert id="insertWelfare" parameterType="com.moa.backend.welfare.model.vo.Welfare">
        INSERT INTO WELFARE (
            PLCY_NO, LCLSF_NM, MCLSF_NM, MRG_STTS_CD, SCHOOL_CD, PLCY_MAJOR_CD, JOB_CD, SBIZ_CD, SPRT_TRGT_MIN_AGE,
            SPRT_TRGT_MAX_AGE, SPRT_TRGT_AGE_LMT_YN, EARN_MIN_AMT, EARN_MAX_AMT, EARN_ETC_CN, FULL_DATA
        ) VALUES (
            #{plcyNo}, #{lclsfNm}, #{mclsfNm}, #{mrgSttsCd}, #{schoolCd}, #{plcyMajorCd}, #{jobCd}, #{sbizCd}, #{sprtTrgtMinAge},
            #{sprtTrgtMaxAge}, #{sprtTrgtAgeLmtYn}, #{earnMinAmt}, #{earnMaxAmt}, #{earnEtcCn}, #{fullData}
        )
    </insert>
	
	<!-- 메인화면 복지서비스 4개 -->
    <select id="getMainWelfare" resultType="com.moa.backend.welfare.model.vo.WelfareListDTO">
        SELECT * FROM (
            SELECT
                WELFARE_ID AS welfareId,
                LCLSF_NM AS lclsfNm,
                JSON_VALUE(FULL_DATA, '$.plcyNm') AS plcyNm,
                JSON_VALUE(FULL_DATA, '$.aplyYmd') AS aplyYmd,
                JSON_VALUE(FULL_DATA, '$.sprvsnInstCdNm') AS sprvsnInstCdNm
            FROM WELFARE
            ORDER BY WELFARE_ID DESC
        )
        WHERE ROWNUM &lt;= 4
    </select>
	
	<!-- 메인화면 인기복지서비스 10개 -->
    <select id="getTopten" resultType="com.moa.backend.welfare.model.vo.WelfareListDTO">
	    SELECT *
	    FROM (
	        SELECT
	            w.WELFARE_ID AS welfareId,
	            w.LCLSF_NM AS lclsfNm,
	            JSON_VALUE(w.FULL_DATA, '$.plcyNm') AS plcyNm,
	            JSON_VALUE(w.FULL_DATA, '$.aplyYmd') AS aplyYmd,
	            JSON_VALUE(w.FULL_DATA, '$.sprvsnInstCdNm') AS sprvsnInstCdNm,
	            COUNT(wi.WELFARE_ID) AS wishCount
	        FROM WELFARE w
	        LEFT JOIN WISH wi ON w.WELFARE_ID = wi.WELFARE_ID
	        GROUP BY w.WELFARE_ID, w.LCLSF_NM,
	            JSON_VALUE(w.FULL_DATA, '$.plcyNm'),
	            JSON_VALUE(w.FULL_DATA, '$.aplyYmd'),
	            JSON_VALUE(w.FULL_DATA, '$.sprvsnInstCdNm')
	        ORDER BY wishCount DESC, w.WELFARE_ID DESC
	    )
	    WHERE ROWNUM &lt;= 10
 	</select>
	
	<!-- 복지서비스화면 모든 복지리스트 불러오기 -->
    <select id="getWelfareDetail" parameterType="Long" resultType="com.moa.backend.welfare.model.vo.WelfareDetailDTO">
        SELECT
            WELFARE_ID AS welfareId,
            LCLSF_NM AS lclsfNm,
            JSON_VALUE(FULL_DATA, '$.plcyNm') AS plcyNm,
            JSON_VALUE(FULL_DATA, '$.sprvsnInstCdNm') AS sprvsnInstCdNm,
            JSON_VALUE(FULL_DATA, '$.lastMdfcnDt') AS lastMdfcnDt,
            JSON_VALUE(FULL_DATA, '$.sprtTrgtMinAge') AS sprtTrgtMinAge,
            JSON_VALUE(FULL_DATA, '$.sprtTrgtMaxAge') AS sprtTrgtMaxAge,
            JSON_VALUE(FULL_DATA, '$.ptcpPrpTrgtCn') AS ptcpPrpTrgtCn,
            JSON_VALUE(FULL_DATA, '$.earnEtcCn') AS earnEtcCn,
            JSON_VALUE(FULL_DATA, '$.plcySprtCn') AS plcySprtCn,
            JSON_VALUE(FULL_DATA, '$.aplyYmd') AS aplyYmd,
            JSON_VALUE(FULL_DATA, '$.plcyAplyMthdCn') AS plcyAplyMthdCn,
            JSON_VALUE(FULL_DATA, '$.srngMthdCn') AS srngMthdCn,
            JSON_VALUE(FULL_DATA, '$.aplyUrlAddr') AS aplyUrlAddr,
            JSON_VALUE(FULL_DATA, '$.plcyExplnCn') AS plcyExplnCn,
            (SELECT COUNT(*) FROM WISH WHERE WELFARE_ID = #{id}) AS wishCount
        FROM WELFARE
        WHERE WELFARE_ID = #{id}
    </select>
	
	<!-- 복지서비스 상세화면 하단 관련복지 추천 -->
    <select id="getRelatedWelfare" resultType="com.moa.backend.welfare.model.vo.WelfareListDTO">
        SELECT * FROM (
            SELECT
                WELFARE_ID AS welfareId,
                LCLSF_NM AS lclsfNm,
                JSON_VALUE(FULL_DATA, '$.plcyNm') AS plcyNm,
                JSON_VALUE(FULL_DATA, '$.aplyYmd') AS aplyYmd,
                JSON_VALUE(FULL_DATA, '$.sprvsnInstCdNm') AS sprvsnInstCdNm
            FROM WELFARE
            WHERE LCLSF_NM LIKE '%' || #{lclsfNm} || '%'
            AND WELFARE_ID != #{excludeId}
            ORDER BY DBMS_RANDOM.VALUE
        )
        WHERE ROWNUM &lt;= 3
    </select>
	
	<!-- 복지리스트화면에서 필터링한 애들만 뽑아오는 쿼리 -->
    <select id="getWelfareList" parameterType="com.moa.backend.welfare.model.vo.WelfareSearchDTO" resultType="com.moa.backend.welfare.model.vo.WelfareListDTO">
		    SELECT
		        w.WELFARE_ID AS welfareId,
		        w.LCLSF_NM AS lclsfNm,
		        JSON_VALUE(w.FULL_DATA, '$.plcyNm') AS plcyNm,
		        JSON_VALUE(w.FULL_DATA, '$.aplyYmd') AS aplyYmd,
		        JSON_VALUE(w.FULL_DATA, '$.sprvsnInstCdNm') AS sprvsnInstCdNm,
		        COUNT(wi.WELFARE_ID) AS wishCount
		    FROM WELFARE w
		    LEFT JOIN WISH wi ON w.WELFARE_ID = wi.WELFARE_ID
		    WHERE 1=1
		    <if test="keyword != null and keyword != ''">
		        AND JSON_VALUE(w.FULL_DATA, '$.plcyNm') LIKE '%' || #{keyword} || '%'
		    </if>
		    <if test="lclsfNm != null and lclsfNm.size() > 0">
		        AND (
		            <foreach collection="lclsfNm" item="cat" separator=" OR ">
		                (w.LCLSF_NM LIKE '%' || #{cat} || '%'
		                <if test="cat == '참여･기반'">OR w.LCLSF_NM LIKE '%참여권리%'</if>
		                <if test="cat == '금융･복지･문화'">OR w.LCLSF_NM LIKE '%복지문화%'</if>
		                <if test="cat == '교육'">OR w.LCLSF_NM LIKE '%교육･직업훈련%'</if>
		                )
		            </foreach>
		        )
		    </if>
		    <if test="region != null and region.size() > 0">
		        AND (
		            <foreach collection="region" item="r" separator=" OR ">
		                 REGEXP_LIKE(JSON_VALUE(w.FULL_DATA, '$.zipCd'), '(^|,)' || #{r} || '[0-9]{3}(,|$)')
		            </foreach>
		        )
		    </if>
		    <if test="ageMin > 0 and ageMax > 0">
		        AND (
		        (w.SPRT_TRGT_MIN_AGE = 0 AND w.SPRT_TRGT_MAX_AGE = 0)
		        OR
		        (w.SPRT_TRGT_MIN_AGE &lt;= #{ageMax} AND w.SPRT_TRGT_MAX_AGE &gt;= #{ageMin})
		        )
		    </if>
		    <if test="income != null and income.size() > 0">
		        AND (
		            <foreach collection="income" item="i" separator=" OR ">
		                JSON_VALUE(w.FULL_DATA, '$.earnCndSeCd') = #{i}
		            </foreach>
		        )
		    </if>
		    <if test="job != null and job.size() > 0">
		        AND (
		            <foreach collection="job" item="j" separator=" OR ">
		                w.JOB_CD LIKE '%' || #{j} || '%'
		            </foreach>
		        )
		    </if>
		    <if test="school != null and school.size() > 0">
			    AND (
			        <foreach collection="school" item="s" separator=" OR ">
			            w.SCHOOL_CD LIKE '%' || #{s} || '%'
			        </foreach>
			    )
			</if>
		    <if test="sort == '진행중'">
		        AND (
		            JSON_VALUE(w.FULL_DATA, '$.aplyYmd') IS NULL
		            OR NOT REGEXP_LIKE(JSON_VALUE(w.FULL_DATA, '$.aplyYmd'), '~')
		            OR TO_DATE(TRIM(REGEXP_SUBSTR(JSON_VALUE(w.FULL_DATA, '$.aplyYmd'), '[0-9]{8}$')), 'YYYYMMDD') &gt;= SYSDATE
		        )
		    </if>
		    <if test="sort == '마감됨'">
		        AND JSON_VALUE(w.FULL_DATA, '$.aplyYmd') IS NOT NULL
		        AND REGEXP_LIKE(JSON_VALUE(w.FULL_DATA, '$.aplyYmd'), '~')
		        AND TO_DATE(TRIM(REGEXP_SUBSTR(JSON_VALUE(w.FULL_DATA, '$.aplyYmd'), '[0-9]{8}$')), 'YYYYMMDD') &lt; SYSDATE
		    </if>
		    GROUP BY w.WELFARE_ID, w.LCLSF_NM,
		        JSON_VALUE(w.FULL_DATA, '$.plcyNm'),
		        JSON_VALUE(w.FULL_DATA, '$.aplyYmd'),
		        JSON_VALUE(w.FULL_DATA, '$.sprvsnInstCdNm')
		    <choose>
		        <when test="sort == '찜 많은순'">
		            ORDER BY wishCount DESC, w.WELFARE_ID DESC
		        </when>
		        <otherwise>
		            ORDER BY w.WELFARE_ID DESC
		        </otherwise>
		    </choose>
		    OFFSET #{offset} ROWS
		    FETCH NEXT #{limit} ROWS ONLY
		</select>

		<!-- 필터조건으로 몇 개가있는지 카운트하는 쿼리 -->
    	<select id="getWelfareCount" parameterType="com.moa.backend.welfare.model.vo.WelfareSearchDTO" resultType="int">
        SELECT COUNT(*) FROM WELFARE
        WHERE 1=1
        <if test="keyword != null and keyword != ''">
            AND JSON_VALUE(FULL_DATA, '$.plcyNm') LIKE '%' || #{keyword} || '%'
        </if>
        <if test="lclsfNm != null and lclsfNm.size() > 0">
            AND (
                <foreach collection="lclsfNm" item="cat" separator=" OR ">
                    (LCLSF_NM LIKE '%' || #{cat} || '%'
                    <if test="cat == '참여･기반'">
                        OR LCLSF_NM LIKE '%참여권리%'
                    </if>
                    <if test="cat == '금융･복지･문화'">
                        OR LCLSF_NM LIKE '%복지문화%'
                    </if>
                    <if test="cat == '교육'">
                        OR LCLSF_NM LIKE '%교육･직업훈련%'
                    </if>
                    )
                </foreach>
            )
        </if>
        <if test="region != null and region.size() > 0">
            AND (
                <foreach collection="region" item="r" separator=" OR ">
                     REGEXP_LIKE(JSON_VALUE(FULL_DATA, '$.zipCd'), '(^|,)' || #{r} || '[0-9]{3}(,|$)')
                </foreach>
            )
        </if>
        <if test="ageMin > 0 and ageMax > 0">
		    AND (
		    (SPRT_TRGT_MIN_AGE = 0 AND SPRT_TRGT_MAX_AGE = 0)
		    OR 
		    (SPRT_TRGT_MIN_AGE &lt;= #{ageMax} AND SPRT_TRGT_MAX_AGE &gt;= #{ageMin})
		    )
		</if>
        <if test="income != null and income.size() > 0">
            AND (
                <foreach collection="income" item="i" separator=" OR ">
                    JSON_VALUE(FULL_DATA, '$.earnCndSeCd') = #{i}
                </foreach>
            )
        </if>
        <if test="job != null and job.size() > 0">
            AND (
                <foreach collection="job" item="j" separator=" OR ">
                    JOB_CD LIKE '%' || #{j} || '%'
                </foreach>
            )
        </if>
        <if test="school != null and school.size() > 0">
		    AND (
		        <foreach collection="school" item="s" separator=" OR ">
		            SCHOOL_CD LIKE '%' || #{s} || '%'
		        </foreach>
		    )
		</if>
		<if test="sort == '진행중'">
		    AND (
		        JSON_VALUE(FULL_DATA, '$.aplyYmd') IS NULL
		        OR NOT REGEXP_LIKE(JSON_VALUE(FULL_DATA, '$.aplyYmd'), '~')
		        OR TO_DATE(TRIM(REGEXP_SUBSTR(JSON_VALUE(FULL_DATA, '$.aplyYmd'), '[0-9]{8}$')), 'YYYYMMDD') &gt;= SYSDATE
		    )
		</if>
		<if test="sort == '마감됨'">
		    AND JSON_VALUE(FULL_DATA, '$.aplyYmd') IS NOT NULL
		    AND REGEXP_LIKE(JSON_VALUE(FULL_DATA, '$.aplyYmd'), '~')
		    AND TO_DATE(TRIM(REGEXP_SUBSTR(JSON_VALUE(FULL_DATA, '$.aplyYmd'), '[0-9]{8}$')), 'YYYYMMDD') &lt; SYSDATE
		</if>		
    </select>
    
    <!-- 메인화면 개인 복지추천 서비스 -->
    <select id="getRecommend" parameterType="map" resultType="com.moa.backend.welfare.model.vo.WelfareListDTO">
	    SELECT *
	    FROM (
	        SELECT
	            w.WELFARE_ID AS welfareId,
	            w.LCLSF_NM AS lclsfNm,
	            JSON_VALUE(w.FULL_DATA, '$.plcyNm') AS plcyNm,
	            JSON_VALUE(w.FULL_DATA, '$.aplyYmd') AS aplyYmd,
	            JSON_VALUE(w.FULL_DATA, '$.sprvsnInstCdNm') AS sprvsnInstCdNm
	        FROM WELFARE w
	        <where>
				<if test="region != null and region != ''">
				    AND REGEXP_LIKE(JSON_VALUE(w.FULL_DATA, '$.zipCd'), '(^|,)' || #{region} || '[0-9]{3}(,|$)')
				</if>
	            <if test="schoolCd != null and schoolCd != ''">
	                AND w.SCHOOL_CD LIKE '%' || #{schoolCd} || '%'
	            </if>
	            <if test="jobCd != null and jobCd != ''">
	                AND w.JOB_CD LIKE '%' || #{jobCd} || '%'
	            </if>
	            <if test="hasWish == true or (earnCndSeCd != null and earnCndSeCd != '')">
	                AND (
	                    <if test="hasWish == true">
	                        w.LCLSF_NM IN (
	                            SELECT DISTINCT w2.LCLSF_NM
	                            FROM WELFARE w2
	                            JOIN WISH wi ON w2.WELFARE_ID = wi.WELFARE_ID
	                            WHERE wi.MEMBER_ID = #{memberId}
	                        )
	                    </if>
	                    <if test="hasWish == true and earnCndSeCd != null and earnCndSeCd != ''"> OR </if>
	                    <if test="earnCndSeCd != null and earnCndSeCd != ''">
	                        JSON_VALUE(w.FULL_DATA, '$.earnCndSeCd') = #{earnCndSeCd}
	                    </if>
	                )
	            </if>
	             AND (
                JSON_VALUE(FULL_DATA, '$.aplyYmd') IS NULL
                OR NOT REGEXP_LIKE(JSON_VALUE(FULL_DATA, '$.aplyYmd'), '~')
                OR TO_DATE(TRIM(REGEXP_SUBSTR(JSON_VALUE(FULL_DATA, '$.aplyYmd'), '[0-9]{8}$')), 'YYYYMMDD') &gt;= SYSDATE
            )
	        </where>
	        ORDER BY DBMS_RANDOM.VALUE
	    )
	    WHERE ROWNUM &lt;= 4
	</select>
	
	
	<select id="countWish" parameterType="Long" resultType="int">
	    SELECT COUNT(*) FROM WISH WHERE MEMBER_ID = #{memberId}
	</select>
	
	<!-- 지역 목록 조회 -->
    <select id="getRegionList" resultType="com.moa.backend.welfare.model.vo.WelfareRegionDTO">
        SELECT DISTINCT 
            SUBSTR(ZIP_CD, 1, 2) AS zipCd,
            REGEXP_SUBSTR(REGION_NAME, '^\S+') AS regionName
        FROM WELFARE_REGION
        ORDER BY zipCd
    </select>

    <!-- 카테고리 코드 목록 조회 -->
    <select id="getCategoryList" resultType="com.moa.backend.welfare.model.vo.WelfareCategoryDTO">
        SELECT 
            m.MAIN_ID AS mainId,
            s.SUB_ID AS subId,
            s.SUB_NAME AS subName
        FROM MAIN_CATEGORY m
        JOIN SUB_CATEGORY s ON m.MAIN_ID = s.MAIN_ID
        ORDER BY m.MAIN_ID, s.SUB_ID
    </select>

    <!-- 지역명(한글) -> 지역코드(2자리) 변환 -->
    <select id="getRegionCode" parameterType="String" resultType="String">
        SELECT DISTINCT SUBSTR(ZIP_CD, 1, 2)
        FROM WELFARE_REGION
        WHERE REGEXP_SUBSTR(REGION_NAME, '^\S+') LIKE #{regionName} || '%'
        FETCH FIRST 1 ROWS ONLY
    </select>
    
    <!-- 페르소나: 상세정보 미 입력시 jobstatus(대학생 등) 기준 -->
	<select id="getPersonaByCode" parameterType="map" resultType="com.moa.backend.welfare.model.vo.WelfareListDTO">
	    SELECT * FROM (
	        SELECT
	            WELFARE_ID AS welfareId,
	            LCLSF_NM AS lclsfNm,
	            JSON_VALUE(FULL_DATA, '$.plcyNm') AS plcyNm,
	            JSON_VALUE(FULL_DATA, '$.aplyYmd') AS aplyYmd,
	            JSON_VALUE(FULL_DATA, '$.sprvsnInstCdNm') AS sprvsnInstCdNm
	        FROM WELFARE
	        <where>
	            <if test="schoolCd != null and schoolCd != ''">
	                AND SCHOOL_CD LIKE '%' || #{schoolCd} || '%'
	            </if>
	            <if test="jobCd != null and jobCd != ''">
	                AND JOB_CD LIKE '%' || #{jobCd} || '%'
	            </if>
	            <if test="lclsfNm != null and lclsfNm != ''">
				    AND (LCLSF_NM LIKE '%' || #{lclsfNm} || '%'
				    <if test="lclsfNm == '참여･기반'">OR LCLSF_NM LIKE '%참여권리%'</if>
				    <if test="lclsfNm == '금융･복지･문화'">OR LCLSF_NM LIKE '%복지문화%'</if>
				    <if test="lclsfNm == '교육'">OR LCLSF_NM LIKE '%교육･직업훈련%'</if>
				    )
				</if>
				 AND (
                JSON_VALUE(FULL_DATA, '$.aplyYmd') IS NULL
                OR NOT REGEXP_LIKE(JSON_VALUE(FULL_DATA, '$.aplyYmd'), '~')
                OR TO_DATE(TRIM(REGEXP_SUBSTR(JSON_VALUE(FULL_DATA, '$.aplyYmd'), '[0-9]{8}$')), 'YYYYMMDD') &gt;= SYSDATE
            )
	        </where>
	        ORDER BY DBMS_RANDOM.VALUE
	    )
	    WHERE ROWNUM &lt;= 4
	</select>

	 <!-- 페르소나: 상세정보 입력시 jobstatus(대학생 등) 기준 -->
	<select id="getPersonaByDetail" parameterType="map" resultType="com.moa.backend.welfare.model.vo.WelfareListDTO">
	    SELECT * FROM (
	        SELECT
	            WELFARE_ID AS welfareId,
	            LCLSF_NM AS lclsfNm,
	            JSON_VALUE(FULL_DATA, '$.plcyNm') AS plcyNm,
	            JSON_VALUE(FULL_DATA, '$.aplyYmd') AS aplyYmd,
	            JSON_VALUE(FULL_DATA, '$.sprvsnInstCdNm') AS sprvsnInstCdNm
	        FROM WELFARE
	        <where>
	            <if test="lclsfNm != null and lclsfNm != ''">
				    AND (LCLSF_NM LIKE '%' || #{lclsfNm} || '%'
				    <if test="lclsfNm == '참여･기반'">OR LCLSF_NM LIKE '%참여권리%'</if>
				    <if test="lclsfNm == '금융･복지･문화'">OR LCLSF_NM LIKE '%복지문화%'</if>
				    <if test="lclsfNm == '교육'">OR LCLSF_NM LIKE '%교육･직업훈련%'</if>
				    )
				</if>
	            <if test="schoolCd != null and schoolCd != ''">
	                AND SCHOOL_CD LIKE '%' || #{schoolCd} || '%'
	            </if>
	            <if test="jobCd != null and jobCd != ''">
	                AND JOB_CD LIKE '%' || #{jobCd} || '%'
	            </if>
	            <if test="region != null and region != ''">
	                AND REGEXP_LIKE(JSON_VALUE(FULL_DATA, '$.zipCd'), '(^|,)' || #{region} || '[0-9]{3}(,|$)')
	            </if>
	            AND (
                JSON_VALUE(FULL_DATA, '$.aplyYmd') IS NULL
                OR NOT REGEXP_LIKE(JSON_VALUE(FULL_DATA, '$.aplyYmd'), '~')
                OR TO_DATE(TRIM(REGEXP_SUBSTR(JSON_VALUE(FULL_DATA, '$.aplyYmd'), '[0-9]{8}$')), 'YYYYMMDD') &gt;= SYSDATE
            )
	        </where>
	        ORDER BY DBMS_RANDOM.VALUE
	    )
	    WHERE ROWNUM &lt;= 4
	</select>
		
		
	<insert id="mergeWelfare" parameterType="com.moa.backend.welfare.model.vo.Welfare">
    MERGE INTO WELFARE w
    USING DUAL ON (w.PLCY_NO = #{plcyNo})
    WHEN MATCHED THEN UPDATE SET
        w.LCLSF_NM = #{lclsfNm},
        w.MCLSF_NM = #{mclsfNm},
        w.MRG_STTS_CD = #{mrgSttsCd},
        w.SCHOOL_CD = #{schoolCd},
        w.PLCY_MAJOR_CD = #{plcyMajorCd},
        w.JOB_CD = #{jobCd},
        w.SBIZ_CD = #{sbizCd},
        w.SPRT_TRGT_MIN_AGE = #{sprtTrgtMinAge},
        w.SPRT_TRGT_MAX_AGE = #{sprtTrgtMaxAge},
        w.SPRT_TRGT_AGE_LMT_YN = #{sprtTrgtAgeLmtYn},
        w.EARN_MIN_AMT = #{earnMinAmt},
        w.EARN_MAX_AMT = #{earnMaxAmt},
        w.EARN_ETC_CN = #{earnEtcCn},
        w.FULL_DATA = #{fullData}
    WHEN NOT MATCHED THEN INSERT (
        PLCY_NO, LCLSF_NM, MCLSF_NM, MRG_STTS_CD, SCHOOL_CD, PLCY_MAJOR_CD,
        JOB_CD, SBIZ_CD, SPRT_TRGT_MIN_AGE, SPRT_TRGT_MAX_AGE, SPRT_TRGT_AGE_LMT_YN,
        EARN_MIN_AMT, EARN_MAX_AMT, EARN_ETC_CN, FULL_DATA
    ) VALUES (
        #{plcyNo}, #{lclsfNm}, #{mclsfNm}, #{mrgSttsCd}, #{schoolCd}, #{plcyMajorCd},
        #{jobCd}, #{sbizCd}, #{sprtTrgtMinAge}, #{sprtTrgtMaxAge}, #{sprtTrgtAgeLmtYn},
        #{earnMinAmt}, #{earnMaxAmt}, #{earnEtcCn}, #{fullData}
    )
</insert>	

</mapper>
