SELECT WELFARE_ID, JSON_VALUE(FULL_DATA, '$.plcyNm'), JSON_VALUE(FULL_DATA, '$.aplyYmd')
FROM WELFARE
WHERE LCLSF_NM LIKE '%금융･복지･문화%'
AND SCHOOL_CD LIKE '%0049005%'
AND (
    JSON_VALUE(FULL_DATA, '$.aplyYmd') IS NULL
    OR NOT REGEXP_LIKE(JSON_VALUE(FULL_DATA, '$.aplyYmd'), '~')
    OR TO_DATE(TRIM(REGEXP_SUBSTR(JSON_VALUE(FULL_DATA, '$.aplyYmd'), '[0-9]{8}$')), 'YYYYMMDD') >= SYSDATE
);
