add profile varchar2(100);

create table todo_list(
    todo_num number primary key,
    todo varchar2(90) not null,
    writer varchar2(30) not null,
    status char(1) default 'I' check(status in('I', 'C')),
    important char(1) default 'N' check(important in('Y', 'N')),
    foreign key(writer) references member
);

